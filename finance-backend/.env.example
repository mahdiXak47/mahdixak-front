# ── Auth ─────────────────────────────────────────────────────────────────────
FINANCE_USER=mahdi

# SHA-256 hex digest of your password. Generate with:
#   node -e "console.log(require('crypto').createHash('sha256').update('yourpassword').digest('hex'))"
# or:
#   echo -n "yourpassword" | sha256sum
FINANCE_PASS_HASH=

# ── Session ───────────────────────────────────────────────────────────────────
# Long random string — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
